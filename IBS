      .hero h1 { font-size: 2.6rem; }
      .blueprint-box, .contact-wrapper { grid-template-columns: 1fr; }
      .telemetry-bar { grid-template-columns: 1fr; }
      .nav-links { display: none; }
    }
  </style>
</head>
